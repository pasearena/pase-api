# Pase Arena API — environment variables
# Copy to .env locally; set these in Railway → Variables for production.

PORT=8080

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx
OPENROUTER_REFERER=https://pasearena.xyz

# Supabase (Project Settings → API)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...   # service_role key (server-side ONLY)

# CORS — your live frontend origin
ALLOWED_ORIGIN=https://pasearena.xyz
